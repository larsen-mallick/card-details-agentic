# Copy this file to .env and fill in your values.
# Never commit the real .env to source control.

# Java card service base URL (default: local dev)
CARD_SERVICE_BASE_URL=http://localhost:8080/card-details

# OpenAI API key (required for GPT-4o)
OPENAI_API_KEY=sk-...

# LLM model to use (default: gpt-4o)
LLM_MODEL=gpt-4o

# HTTP timeout for card service calls (seconds)
REQUEST_TIMEOUT_SECONDS=10
